# Copy to .env and fill in. Used by docker-compose for the local hosted stack.

# --- Which ACA Job should Airflow drive ---
AZURE_SUBSCRIPTION_ID=
ACA_RESOURCE_GROUP=
ACA_JOB_NAME=

# --- Local web UI port (optional; default 8080). Change to avoid port conflicts. ---
AIRFLOW_WEB_PORT=8080

# --- Azure auth: pick ONE option ---

# Option A: a short-lived ARM token (quickest for a local demo).
#   az account get-access-token --resource https://management.azure.com --query accessToken -o tsv
AZURE_ACCESS_TOKEN=

# Option B: a service principal (auto-refreshes via DefaultAzureCredential).
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
